{
  "name": "company-library",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check src/ test/ --write",
    "lint:ci": "biome ci src/ test/ --reporter=github",
    "test": "vitest",
    "typeCheck": "next typegen && tsc --pretty --noEmit",
    "db:generate": "npx prisma generate",
    "db:push": "dotenv -e .env.development.local -- npx prisma db push",
    "db:console": "dotenv -e .env.development.local -- npx prisma studio",
    "db:seed": "dotenv -e .env.development.local -- npx prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^6.19.2",
    "@slack/webhook": "^7.0.9",
    "@vercel/blob": "^2.3.3",
    "graphql": "^16.13.2",
    "luxon": "^3.7.2",
    "next": "16.2.3",
    "next-auth": "^4.24.14",
    "prisma": "^6.19.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "swr": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "daisyui": "^5.5.19",
    "dotenv-cli": "^11.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5",
    "vitest-mock-extended": "^4.0.0"
  },
  "volta": {
    "node": "24.15.0",
    "yarn": "4.14.1"
  }
}
